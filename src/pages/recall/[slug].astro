---
import Base from '../../layouts/Base.astro';
import AdSlot from '../../components/ads/AdSlot.astro';
import { getRecallBySlug, getRelatedRecalls, getAllCategories } from '../../lib/db';
import { agencyLabel, formatDate, severityLabel, severityBg, classLabel, statusLabel, truncate } from '../../lib/format';

const { slug } = Astro.params;
const env = Astro.locals.runtime.env;
const recall = await getRecallBySlug(env, slug!);
if (!recall) return Astro.redirect('/404');

const related = await getRelatedRecalls(env, recall, 6);

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: agencyLabel(recall.agency), url: `/agency/${recall.agency.replace(/_/g, '-')}` },
  { name: truncate(recall.title, 60), url: `/recall/${recall.slug}` },
];

const severityMap: Record<number, string> = { 1: 'Critical', 2: 'Moderate', 3: 'Low' };

// Data-rich title with key metrics
const titleParts = [truncate(recall.title, 80)];
if (recall.severity) titleParts.push(severityMap[recall.severity] || 'Unknown');
if (recall.recalling_firm) titleParts.push(recall.recalling_firm);
const title = `${titleParts.join(' — ')} | ${agencyLabel(recall.agency)} Recall | PlainRecalls`;
const description = truncate(
  `${recall.title}. ${recall.reason || recall.product_description || ''}${recall.recalling_firm ? ` Recalled by ${recall.recalling_firm}.` : ''}${recall.date_reported ? ` Reported ${formatDate(recall.date_reported)}.` : ''}${recall.affected_count ? ` ${recall.affected_count} units affected.` : ''}`,
  155
);

// Determine agency type for cross-DB linking
const isVehicle = recall.agency === 'nhtsa';
const isDrug = recall.agency === 'fda_drug' || recall.agency === 'fda_device';
const isFood = recall.agency === 'fda_food' || recall.agency === 'usda';
const isCPSC = recall.agency === 'cpsc';

// FAQ items
const faqItems: { q: string; a: string }[] = [];
if (recall.product_description || recall.title) {
  faqItems.push({
    q: `What product was recalled?`,
    a: `${recall.product_description || recall.title}.${recall.recalling_firm ? ` Recalled by ${recall.recalling_firm}.` : ''}${recall.affected_count ? ` Units affected: ${recall.affected_count}.` : ''}`
  });
}
if (recall.reason) {
  faqItems.push({
    q: `Why was this product recalled?`,
    a: recall.reason
  });
}
if (recall.remedy) {
  faqItems.push({
    q: `What should consumers do?`,
    a: recall.remedy
  });
}
faqItems.push({
  q: `Which agency issued this recall?`,
  a: `This recall was issued by the ${agencyLabel(recall.agency)}${recall.date_reported ? ` on ${formatDate(recall.date_reported)}` : ''}.${recall.severity ? ` Severity: ${severityMap[recall.severity] || 'Unknown'}.` : ''}${recall.recall_number ? ` Recall number: ${recall.recall_number}.` : ''}`
});
if (recall.distribution) {
  faqItems.push({
    q: `Where was the recalled product distributed?`,
    a: `Distribution: ${recall.distribution}.`
  });
}
faqItems.push({
  q: `How do I check if my product is affected by a recall?`,
  a: `Check the product description and recall number (${recall.recall_number || 'see above'}) against your product. Visit the official ${agencyLabel(recall.agency)} website for the most current information. You can also use our Recall Checker tool to search by product name or brand.`
});

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
});

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((b, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: b.name,
    item: `https://plainrecalls.com${b.url}`,
  })),
});

// Dataset schema (NOT Product — this is a data page, not a product page)
const datasetSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: `${agencyLabel(recall.agency)} Recall: ${truncate(recall.title, 100)}`,
  description: truncate(recall.reason || recall.product_description || recall.title, 5000),
  url: new URL(Astro.url.pathname, Astro.site).href,
  ...(recall.date_reported && { datePublished: recall.date_reported }),
  creator: {
    '@type': 'Organization',
    name: agencyLabel(recall.agency),
  },
  license: 'https://creativecommons.org/publicdomain/zero/1.0/',
  isAccessibleForFree: true,
  distribution: {
    '@type': 'DataDownload',
    encodingFormat: 'text/html',
    contentUrl: new URL(Astro.url.pathname, Astro.site).href,
  },
});
---

<Base
  title={title}
  description={description}
  breadcrumbs={breadcrumbs}
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />
  <script type="application/ld+json" set:html={faqSchema} />
  <script type="application/ld+json" set:html={datasetSchema} />

  <div class="mx-auto max-w-4xl px-4 py-8 md:py-12">
    <!-- Header -->
    <div class="flex flex-wrap items-center gap-2 text-sm">
      <a href={`/agency/${recall.agency.replace(/_/g, '-')}`} class="rounded-full bg-gray-100 px-3 py-1 font-medium text-gray-700 dark:bg-gray-800 dark:text-gray-300">
        {agencyLabel(recall.agency)}
      </a>
      <span class:list={['badge', severityBg(recall.severity)]}>{severityLabel(recall.severity)}</span>
      {recall.classification && (
        <span class="badge bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300">{classLabel(recall.classification)}</span>
      )}
      {recall.status && (
        <span class="badge bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300">{statusLabel(recall.status)}</span>
      )}
    </div>

    <h1 class="mt-4 text-2xl font-bold text-gray-900 dark:text-white md:text-3xl leading-tight">
      {recall.title}
    </h1>

    <div class="mt-3 flex flex-wrap gap-4 text-sm text-gray-500 dark:text-gray-400">
      {recall.date_reported && <span>Reported: {formatDate(recall.date_reported)}</span>}
      {recall.date_initiated && <span>Initiated: {formatDate(recall.date_initiated)}</span>}
      {recall.recall_number && <span>#{recall.recall_number}</span>}
      {recall.affected_count && <span>{recall.affected_count} units</span>}
    </div>

    <AdSlot position="top" />

    <!-- H2 #1: Product Description -->
    <div class="mt-8 space-y-6">
      {recall.product_description && (
        <div class="card">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Product Description</h2>
          <p class="mt-2 text-gray-700 dark:text-gray-300 leading-relaxed">{recall.product_description}</p>
        </div>
      )}

      <!-- H2 #2: Reason for Recall -->
      {recall.reason && (
        <div class="card border-amber-200 dark:border-amber-800/50">
          <h2 class="text-lg font-semibold text-amber-700 dark:text-amber-400">Reason for Recall</h2>
          <p class="mt-2 text-gray-700 dark:text-gray-300 leading-relaxed">{recall.reason}</p>
        </div>
      )}

      <!-- Hazard -->
      {recall.hazard && recall.hazard !== recall.reason && (
        <div class="card border-red-200 dark:border-red-800/50">
          <h2 class="text-lg font-semibold text-amber-700 dark:text-amber-400">Hazard</h2>
          <p class="mt-2 text-gray-700 dark:text-gray-300 leading-relaxed">{recall.hazard}</p>
        </div>
      )}

      <!-- H2 #3: Remedy -->
      {recall.remedy && (
        <div class="card border-teal-200 dark:border-teal-800/50">
          <h2 class="text-lg font-semibold text-teal-700 dark:text-teal-400">Remedy</h2>
          <p class="mt-2 text-gray-700 dark:text-gray-300 leading-relaxed">{recall.remedy}</p>
        </div>
      )}

      <!-- H2 #4: Details -->
      <div class="card">
        <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Details</h2>
        <dl class="mt-3 grid grid-cols-1 gap-3 text-sm sm:grid-cols-2">
          {recall.recalling_firm && (
            <div>
              <dt class="font-medium text-gray-500 dark:text-gray-400">Recalling Firm</dt>
              <dd class="mt-0.5 text-gray-900 dark:text-white">
                {recall.manufacturer_id
                  ? <a href={`/manufacturer/${recall.manufacturer_id}`} class="text-primary-600 dark:text-primary-400 hover:underline">{recall.recalling_firm}</a>
                  : recall.recalling_firm
                }
              </dd>
            </div>
          )}
          {recall.affected_count && (
            <div>
              <dt class="font-medium text-gray-500 dark:text-gray-400">Units Affected</dt>
              <dd class="mt-0.5 text-gray-900 dark:text-white">{recall.affected_count}</dd>
            </div>
          )}
          {recall.distribution && (
            <div class="sm:col-span-2">
              <dt class="font-medium text-gray-500 dark:text-gray-400">Distribution</dt>
              <dd class="mt-0.5 text-gray-900 dark:text-white">{recall.distribution}</dd>
            </div>
          )}
          {(recall.city || recall.state) && (
            <div>
              <dt class="font-medium text-gray-500 dark:text-gray-400">Location</dt>
              <dd class="mt-0.5 text-gray-900 dark:text-white">{[recall.city, recall.state].filter(Boolean).join(', ')}</dd>
            </div>
          )}
          {recall.url && (
            <div class="sm:col-span-2">
              <dt class="font-medium text-gray-500 dark:text-gray-400">Official Source</dt>
              <dd class="mt-0.5"><a href={recall.url} target="_blank" rel="noopener" class="text-primary-600 dark:text-primary-400 hover:underline break-all">{recall.url}</a></dd>
            </div>
          )}
        </dl>
      </div>
    </div>

    <AdSlot position="mid" />

    <!-- H2 #5: FAQ -->
    <div class="mt-8">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Frequently Asked Questions</h2>
      <div class="space-y-3">
        {faqItems.map(f => (
          <details class="group card">
            <summary class="flex items-center justify-between cursor-pointer font-medium text-gray-900 dark:text-white">
              {f.q}
              <span class="ml-2 text-gray-400 group-open:rotate-180 transition-transform">&#9660;</span>
            </summary>
            <div class="mt-3 text-gray-600 dark:text-gray-300 text-sm">{f.a}</div>
          </details>
        ))}
      </div>
    </div>

    <!-- Content Narrative -->
    <div class="mt-10 card border-gray-200 dark:border-gray-700">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Recall Context</h2>
      <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
        Product recalls are issued when a manufacturer, distributor, or federal agency determines that a product poses a safety risk to consumers. {recall.severity === 1 ? 'This recall is classified as critical severity, meaning the product carries a reasonable probability of serious adverse health consequences or death.' : recall.severity === 2 ? 'This recall is classified as moderate severity, indicating the product may cause temporary or medically reversible health consequences.' : 'Recall severity varies based on the likelihood and degree of potential harm to consumers.'} Across PlainRecalls, we track 83,000+ recalls from FDA, CPSC, and NHTSA to help consumers stay informed and act quickly when safety issues arise.
      </p>
    </div>

    <!-- H2 #6: Cross-DB Enrichment Links -->
    <div class="mt-10">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4">Related Safety Data</h2>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Explore related product safety and public health data from federal sources.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="https://plainsafety.com" target="_blank" rel="noopener"
          class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100 dark:bg-gray-900 dark:ring-gray-800 hover:ring-primary-500 transition-colors block">
          <p class="text-lg mb-1">&#9888;&#65039;</p>
          <p class="font-bold text-gray-900 dark:text-white">Product Injury Data</p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">CPSC emergency room injury data for 838 product categories — 7.3M NEISS records tracking real-world consumer product injuries.</p>
          <p class="text-xs text-primary-600 dark:text-primary-400 mt-2">PlainSafety &rarr;</p>
        </a>
        <a href="https://plaincars.com" target="_blank" rel="noopener"
          class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100 dark:bg-gray-900 dark:ring-gray-800 hover:ring-primary-500 transition-colors block">
          <p class="text-lg mb-1">&#128663;</p>
          <p class="font-bold text-gray-900 dark:text-white">{isVehicle ? 'Vehicle Safety Data' : 'Vehicle Recalls & Safety'}</p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">{isVehicle ? 'NHTSA complaints, investigations, and reliability scores for 3,500+ vehicle models with 2M+ complaints.' : 'NHTSA vehicle safety complaints, recall campaigns, and reliability scores across 3,500+ models.'}</p>
          <p class="text-xs text-primary-600 dark:text-primary-400 mt-2">PlainCars &rarr;</p>
        </a>
        {isDrug && (
          <a href="https://plainmeds.com" target="_blank" rel="noopener"
            class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100 dark:bg-gray-900 dark:ring-gray-800 hover:ring-primary-500 transition-colors block">
            <p class="text-lg mb-1">&#128138;</p>
            <p class="font-bold text-gray-900 dark:text-white">Drug Information</p>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">FDA drug data for 680+ medications — interactions, alternatives, side effects, and safety information.</p>
            <p class="text-xs text-primary-600 dark:text-primary-400 mt-2">PlainMeds &rarr;</p>
          </a>
        )}
        {isFood && (
          <a href="https://getfoodfacts.com" target="_blank" rel="noopener"
            class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100 dark:bg-gray-900 dark:ring-gray-800 hover:ring-primary-500 transition-colors block">
            <p class="text-lg mb-1">&#127829;</p>
            <p class="font-bold text-gray-900 dark:text-white">Nutrition Data</p>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">USDA nutrition facts for 2M+ food items — calories, macros, vitamins, and ingredient analysis.</p>
            <p class="text-xs text-primary-600 dark:text-primary-400 mt-2">GetFoodFacts &rarr;</p>
          </a>
        )}
        {isCPSC && (
          <a href="https://plainbreed.com" target="_blank" rel="noopener"
            class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100 dark:bg-gray-900 dark:ring-gray-800 hover:ring-primary-500 transition-colors block">
            <p class="text-lg mb-1">&#128054;</p>
            <p class="font-bold text-gray-900 dark:text-white">Pet Product Safety</p>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">FDA animal adverse event reports — medication reactions and product safety data for 500+ breeds.</p>
            <p class="text-xs text-primary-600 dark:text-primary-400 mt-2">PlainBreed &rarr;</p>
          </a>
        )}
        <a href="/checker/" 
          class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100 dark:bg-gray-900 dark:ring-gray-800 hover:ring-primary-500 transition-colors block">
          <p class="text-lg mb-1">&#128269;</p>
          <p class="font-bold text-gray-900 dark:text-white">Recall Checker</p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Search our database of 83K+ recalls by product name, brand, or recall number across all agencies.</p>
          <p class="text-xs text-primary-600 dark:text-primary-400 mt-2">Check Now &rarr;</p>
        </a>
        <a href="/radar/"
          class="rounded-xl bg-white p-5 shadow-sm ring-1 ring-gray-100 dark:bg-gray-900 dark:ring-gray-800 hover:ring-primary-500 transition-colors block">
          <p class="text-lg mb-1">&#128225;</p>
          <p class="font-bold text-gray-900 dark:text-white">Recall Radar</p>
          <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Live feed of the latest recalls across FDA, CPSC, NHTSA, and USDA — filter by agency and severity.</p>
          <p class="text-xs text-primary-600 dark:text-primary-400 mt-2">View Radar &rarr;</p>
        </a>
      </div>
    </div>

    <!-- H2 #7: Related Recalls -->
    {related.length > 0 && (
      <div class="mt-10">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white">Related Recalls</h2>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 mb-4">Other recalls in the same product category.</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          {related.map(r => (
            <a href={`/recall/${r.slug}`} class="block card hover:shadow-md transition-shadow">
              <div class="flex items-center gap-2">
                <span class="text-xs font-medium text-gray-500 dark:text-gray-400">{agencyLabel(r.agency)}</span>
                <span class:list={['badge text-xs', severityBg(r.severity)]}>{severityLabel(r.severity)}</span>
              </div>
              <h3 class="mt-1 text-sm font-semibold text-gray-900 dark:text-white">{truncate(r.title, 120)}</h3>
              <p class="mt-0.5 text-xs text-gray-500">{r.recalling_firm} &middot; {r.date_reported}</p>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- H2 #8: Data Sources -->
    <div class="mt-10">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Data Sources</h2>
      <div class="card text-sm text-gray-600 dark:text-gray-400">
        <ul class="space-y-1 list-disc list-inside">
          <li><strong>FDA:</strong> Food and Drug Administration — food, drug, and medical device recalls via openFDA</li>
          <li><strong>CPSC:</strong> Consumer Product Safety Commission — consumer product recalls and hazards</li>
          <li><strong>NHTSA:</strong> National Highway Traffic Safety Administration — vehicle safety recalls</li>
          <li><strong>USDA FSIS:</strong> Food Safety and Inspection Service — meat, poultry, and egg product recalls</li>
        </ul>
        <p class="mt-3">Recall information is sourced from official federal agency databases. Always verify recall details with the issuing agency for the most current status. This information is for research and awareness purposes only.</p>
      </div>
    </div>
  </div>

  <AdSlot position="bottom" />
</Base>
