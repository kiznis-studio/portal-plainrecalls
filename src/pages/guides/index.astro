---
export const prerender = false;
import Base from '../../layouts/Base.astro';

const guides = [
  { slug: 'how-us-recall-system-works', title: 'How the US Recall System Works', description: 'The three federal agencies that manage product recalls, how recalls are initiated, and what happens after a recall is announced.' },
  { slug: 'checking-products-for-recalls', title: 'How to Check If Your Products Are Recalled', description: 'Step-by-step guide to checking food, consumer products, medications, and vehicles for active recalls using federal databases.' },
  { slug: 'recall-severity-classes', title: 'Understanding Recall Severity Classes', description: 'What FDA Class I, II, and III mean, how CPSC and NHTSA classify recall urgency, and which recalls demand immediate action.' },
];
---

<Base title="Recall Guides — PlainRecalls" description="Educational guides on product recalls, how to check for recalled products, and understanding recall severity from FDA, CPSC, and NHTSA data.">
  <div class="mx-auto max-w-4xl px-4 py-8 md:py-12">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-3">Recall Guides</h1>
    <p class="text-gray-600 dark:text-gray-400 mb-8 max-w-2xl">
      Learn how recalls work and how to protect yourself using official federal data.
      These guides cover the three agencies that manage US product recalls — the
      FDA (food and drugs), CPSC (consumer products), and NHTSA (vehicles) —
      explain severity classifications, and show you how to check 83,000+
      recall records for items in your home.
    </p>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {guides.map(g => (
        <a href={`/guides/${g.slug}`} class="block p-6 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-red-400 dark:hover:border-red-500 transition-colors">
          <h2 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2">{g.title}</h2>
          <p class="text-sm text-gray-500 dark:text-gray-400">{g.description}</p>
        </a>
      ))}
    </div>
  </div>
</Base>
